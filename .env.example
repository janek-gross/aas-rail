# Host directories mounted by Docker Compose. Use absolute paths.
DATA_PATH=C:/path/to/aas-rail-data
NEO4J_PATH=C:/path/to/neo4j

# Git identity used inside the development container.
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# Neo4j connection. The Compose service uses NEO4J_PASSWORD to initialize Neo4j.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_IMPORT_DIR=
NEO4J_IMPORT_URI_ROOT=file:///var/lib/neo4j/import

# Configure the model providers you use; leave the others empty.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
OLLAMA_ENDPOINT=http://host.docker.internal:11434/v1
LLAMA_ENDPOINT=http://host.docker.internal:8080/v1
OLLAMA_API_KEY=
LLAMA_API_KEY=

# Optional ETIM API credentials.
ETIM_CLIENT_ID=
ETIM_CLIENT_SECRET=
