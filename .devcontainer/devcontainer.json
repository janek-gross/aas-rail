{
  "name": "aas-rail",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "aas-rail",
  "workspaceFolder": "/home/aas-rail/aas-rail",
  "shutdownAction": "stopCompose",
  "extensions": [
    "ms-python.python",
    "ms-toolsai.jupyter"
  ],
    "settings": {
      "python.defaultInterpreterPath": "/home/aas-rail/.venv/bin/python"
    },
  "postStartCommand": "pip install -e '.[app,dev,perturbation]'"
}
